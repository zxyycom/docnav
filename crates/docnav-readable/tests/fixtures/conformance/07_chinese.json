{
  "description": "Chinese characters: each CJK character occupies 3 UTF-8 bytes. The byte_length in the header reference and block marker must reflect the UTF-8 byte count, not the character count. '你好世界' = 4 chars × 3 bytes = 12 bytes.",
  "view_kind": "read",
  "config_override": null,
  "expected_failure": null,
  "input": {
    "ref": "zh-test",
    "content": "你好世界",
    "content_type": "text/plain",
    "cost": "",
    "page": null
  },
  "assertions": [
    {"type": "block", "pointer": "/content", "byte_length": 12, "payload_contains": "你好世界"},
    {"type": "header_contains", "text": "\"bytes\": 12"},
    {"type": "output_contains", "text": "[block /content bytes=12]"},
    {"type": "output_contains", "text": "[endblock /content]"},
    {"type": "no_cr_in_framing"}
  ]
}
