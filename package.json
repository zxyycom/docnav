{
  "name": "docnav-contract-docs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "lint:scripts": "eslint --max-warnings 0 --cache --cache-location .eslintcache --cache-strategy content eslint.config.ts scripts/**/*.ts test/**/*.ts",
    "typecheck:scripts": "tsgo -p tsconfig.json",
    "typecheck:scripts:tsc": "tsc -p tsconfig.json",
    "package:docnav": "bun scripts/release-package/build.ts",
    "info:docnav-package": "bun scripts/release-package/info.ts",
    "cli:dev": "bun scripts/cargo/with-bins.ts --bin docnav:docnav:DOCNAV_BIN --bin docnav-markdown:docnav-markdown:DOCNAV_MARKDOWN_BIN -- bun scripts/docnav-dev/run.ts",
    "dnm": "bun scripts/cargo/with-bins.ts --quiet --bin docnav-markdown:docnav-markdown:DOCNAV_MARKDOWN_BIN -- bun scripts/docnav-dev/run.ts docnav-markdown",
    "smoke:docnav-core:dev": "bun scripts/cargo/with-bins.ts --bin docnav:docnav:DOCNAV_BIN --bin docnav-markdown:docnav-markdown:DOCNAV_MARKDOWN_BIN -- bun test/docnav-core-smoke.ts",
    "smoke:docnav-markdown:dev": "bun scripts/cargo/with-bins.ts --bin docnav-markdown:docnav-markdown:DOCNAV_MARKDOWN_BIN -- bun test/docnav-markdown-smoke.ts",
    "smoke:docnav": "bun scripts/docnav-dev/smoke.ts",
    "verify:docnav-package": "bun scripts/release-package/verify.ts",
    "smoke:docnav-package": "bun scripts/release-package/smoke.ts",
    "test:workspace-verifier": "bun test scripts/docnav-workspace/verify.test.ts test/tools/smoke-harness.test.ts scripts/tools/parallel-task-runner/index.test.ts",
    "test:validators": "bun test scripts/tools/validators",
    "test:release-package-scripts": "bun test scripts/tools/release-package/args.test.ts",
    "verify:docnav-workspace": "bun scripts/docnav-workspace/verify.ts",
    "verify:docnav-workspace:required": "bun scripts/docnav-workspace/verify.ts --profile required",
    "verify:docnav-workspace:full": "bun scripts/docnav-workspace/verify.ts --profile full",
    "validate": "bun run validate:diagnostics && bun run validate:docs && bun run validate:openspec && bun run validate:diff",
    "validate:docs": "bun scripts/docs/validate.ts",
    "validate:diagnostics": "bun scripts/check-diagnostic-projections.ts",
    "validate:openspec": "openspec validate --all --strict",
    "validate:diff": "git diff --check",
    "quality:check": "bun scripts/quality/scan.ts --profile quick --artifact-dir artifacts/docnav-quality/quick",
    "quality:full-check": "bun scripts/quality/scan.ts --profile full --with-baseline",
    "quality:scan": "bun scripts/quality/scan.ts",
    "quality:annotate": "bun scripts/quality/annotate.ts",
    "quality:test": "bun test scripts/tools/quality"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@fission-ai/openspec": "1.3.1",
    "@types/node": "^24.13.2",
    "@typescript/native-preview": "7.0.0-dev.20260621.1",
    "ajv": "^8.17.1",
    "csv-parse": "^7.0.0",
    "eslint": "^10.5.0",
    "execa": "^9.6.1",
    "fast-xml-parser": "^5.9.2",
    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "minimatch": "^10.2.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  }
}
