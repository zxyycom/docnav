{
  "name": "docnav-contract-docs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.3",
  "scripts": {
    "generate:error-rules": "node scripts/generate-error-rules.mjs",
    "package:docnav": "node scripts/package-docnav.mjs",
    "info:docnav-package": "node scripts/release-package-info.mjs",
    "cli:dev": "node scripts/with-cargo-bins.mjs --bin docnav docnav DOCNAV_BIN --bin docnav-markdown docnav-markdown DOCNAV_MARKDOWN_BIN -- node scripts/run-docnav-dev.mjs",
    "dnm": "node scripts/with-cargo-bins.mjs --quiet --bin docnav-markdown docnav-markdown DOCNAV_MARKDOWN_BIN -- node scripts/run-docnav-dev.mjs docnav-markdown",
    "smoke:docnav-core:dev": "node scripts/with-cargo-bins.mjs --bin docnav docnav DOCNAV_BIN --bin docnav-markdown docnav-markdown DOCNAV_MARKDOWN_BIN -- node test/docnav-core-smoke.mjs",
    "smoke:docnav-markdown:dev": "node scripts/with-cargo-bins.mjs --bin docnav-markdown docnav-markdown DOCNAV_MARKDOWN_BIN -- node test/docnav-markdown-smoke.mjs",
    "smoke:docnav": "node scripts/smoke-docnav-dev.mjs",
    "verify:docnav-package": "node scripts/verify-docnav-package.mjs",
    "smoke:docnav-package": "node scripts/docnav-package-smoke.mjs",
    "test:workspace-verifier": "node --test scripts/tools/verify-docnav-workspace.test.mjs test/tools/smoke-harness.test.mjs scripts/tools/parallel-task-runner.test.mjs",
    "test:release-package-scripts": "node --test scripts/tools/release-package/args.test.mjs",
    "verify:docnav-workspace": "node scripts/verify-docnav-workspace.mjs",
    "verify:docnav-workspace:required": "node scripts/verify-docnav-workspace.mjs --profile required",
    "verify:docnav-workspace:full": "node scripts/verify-docnav-workspace.mjs --profile full",
    "validate": "pnpm run validate:generated && pnpm run validate:docs && pnpm run validate:openspec && pnpm run validate:diff",
    "validate:docs": "node scripts/validate-docs.mjs",
    "validate:generated": "node scripts/generate-error-rules.mjs --check",
    "validate:json": "node scripts/validate-docs.mjs json",
    "validate:schema": "node scripts/validate-docs.mjs schema",
    "validate:mcp": "node scripts/validate-docs.mjs mcp",
    "validate:semantics": "node scripts/validate-docs.mjs semantics",
    "validate:links": "node scripts/validate-docs.mjs links",
    "validate:openspec": "openspec validate --all --strict",
    "validate:diff": "git diff --check",
    "quality:scan": "node scripts/quality-scan.mjs",
    "quality:annotate": "node scripts/quality-annotate.mjs",
    "quality:test": "node --test scripts/tools/quality/tools.test.mjs"
  },
  "devDependencies": {
    "@fission-ai/openspec": "1.3.1",
    "ajv": "^8.17.1",
    "minimatch": "^10.2.5"
  }
}
