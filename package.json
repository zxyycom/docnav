{
  "name": "docnav-contract-docs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "env:check": "bun scripts/project-environment/index.ts check",
    "env:setup": "bun scripts/project-environment/index.ts setup",
    "lint:scripts": "eslint --max-warnings 0 --cache --cache-location .eslintcache --cache-strategy content",
    "typecheck:scripts": "tsgo -p tsconfig.json",
    "package:docnav": "mise exec -- bun scripts/release-package/build.ts",
    "info:docnav-package": "mise exec -- bun scripts/release-package/info.ts",
    "dnm": "bun scripts/docnav-dev/with-docnav.ts --quiet bun scripts/docnav-dev/run.ts",
    "smoke:docnav": "bun scripts/docnav-dev/with-docnav.ts bun test/docnav-core-smoke.ts",
    "verify:docnav-package": "bun scripts/release-package/verify.ts",
    "smoke:docnav-package": "bun scripts/release-package/smoke.ts",
    "test:workspace-verifier": "bun test scripts/docnav-workspace/verify.test.ts scripts/project-environment/workspaces.test.ts test/tools/smoke-harness.test.ts test/smoke/core/fixtures/project.test.ts scripts/tools/foundation/test/foundation.test.ts scripts/tools/parallel-task-runner/test/index.test.ts",
    "test:validators": "bun test scripts/tools/validators",
    "test:release-package-scripts": "bun test scripts/tools/release-package/args.test.ts",
    "verify:docnav-workspace": "mise exec -- bun scripts/docnav-workspace/verify.ts",
    "verify:docnav-workspace:required": "mise exec -- bun scripts/docnav-workspace/verify.ts --profile required",
    "validate:docs": "bun scripts/docs/validate.ts",
    "validate:openspec": "bun run openspec validate --all --strict",
    "quality:check": "bun scripts/quality/scan.ts --profile quick --artifact-dir artifacts/docnav-quality/quick",
    "quality:full-check": "bun scripts/quality/scan.ts --profile full --with-baseline",
    "quality:annotate": "bun scripts/quality/annotate.ts",
    "quality:test": "bun test scripts/tools/quality-core scripts/quality/args.test.ts scripts/quality/config.test.ts scripts/quality/annotate/warnings.test.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@fission-ai/openspec": "1.3.1",
    "@types/node": "^24.13.2",
    "@typescript/native-preview": "7.0.0-dev.20260621.1",
    "ajv": "^8.17.1",
    "csv-parse": "^7.0.0",
    "eslint": "^10.5.0",
    "execa": "^9.6.1",
    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "jscpd": "5.0.11",
    "minimatch": "^10.2.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  }
}
