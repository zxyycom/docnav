{
  "name": "docnav-contract-docs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "lint:scripts": "eslint --max-warnings 0 --cache --cache-location .eslintcache --cache-strategy content eslint.config.ts scripts/**/*.ts test/**/*.ts",
    "typecheck:scripts": "tsc -p tsconfig.json",
    "generate:error-rules": "node scripts/generate-error-rules.ts",
    "package:docnav": "node scripts/release-package/build.ts",
    "info:docnav-package": "node scripts/release-package/info.ts",
    "cli:dev": "node scripts/cargo/with-bins.ts --bin docnav:docnav:DOCNAV_BIN --bin docnav-markdown:docnav-markdown:DOCNAV_MARKDOWN_BIN -- node scripts/docnav-dev/run.ts",
    "dnm": "node scripts/cargo/with-bins.ts --quiet --bin docnav-markdown:docnav-markdown:DOCNAV_MARKDOWN_BIN -- node scripts/docnav-dev/run.ts docnav-markdown",
    "smoke:docnav-core:dev": "node scripts/cargo/with-bins.ts --bin docnav:docnav:DOCNAV_BIN --bin docnav-markdown:docnav-markdown:DOCNAV_MARKDOWN_BIN -- node test/docnav-core-smoke.ts",
    "smoke:docnav-markdown:dev": "node scripts/cargo/with-bins.ts --bin docnav-markdown:docnav-markdown:DOCNAV_MARKDOWN_BIN -- node test/docnav-markdown-smoke.ts",
    "smoke:docnav": "node scripts/docnav-dev/smoke.ts",
    "verify:docnav-package": "node scripts/release-package/verify.ts",
    "smoke:docnav-package": "node scripts/release-package/smoke.ts",
    "test:workspace-verifier": "node --test scripts/docnav-workspace/verify.test.ts test/tools/smoke-harness.test.ts scripts/tools/parallel-task-runner/index.test.ts",
    "test:validators": "node --test scripts/tools/validators/**/*.test.ts",
    "test:release-package-scripts": "node --test scripts/tools/release-package/args.test.ts",
    "verify:docnav-workspace": "node scripts/docnav-workspace/verify.ts",
    "verify:docnav-workspace:required": "node scripts/docnav-workspace/verify.ts --profile required",
    "verify:docnav-workspace:full": "node scripts/docnav-workspace/verify.ts --profile full",
    "validate": "pnpm run validate:generated && pnpm run validate:docs && pnpm run validate:openspec && pnpm run validate:diff",
    "validate:docs": "node scripts/docs/validate.ts",
    "validate:generated": "node scripts/generate-error-rules.ts --check",
    "validate:openspec": "openspec validate --all --strict",
    "validate:diff": "git diff --check",
    "quality:check": "node scripts/quality/scan.ts --profile quick --artifact-dir artifacts/docnav-quality/quick",
    "quality:full-check": "node scripts/quality/scan.ts --profile full --with-baseline",
    "quality:scan": "node scripts/quality/scan.ts",
    "quality:annotate": "node scripts/quality/annotate.ts",
    "quality:test": "node --test scripts/tools/quality/**/*.test.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@fission-ai/openspec": "1.3.1",
    "@types/node": "^24.13.2",
    "ajv": "^8.17.1",
    "csv-parse": "^7.0.0",
    "eslint": "^10.5.0",
    "execa": "^9.6.1",
    "fast-xml-parser": "^5.9.2",
    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "minimatch": "^10.2.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  }
}
