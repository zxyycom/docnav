{
  "name": "docnav-contract-docs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.3",
  "scripts": {
    "lint:scripts": "eslint --max-warnings 0 --cache --cache-location .eslintcache --cache-strategy content eslint.config.ts scripts/**/*.ts test/**/*.ts",
    "typecheck:scripts": "tsc -p tsconfig.scripts.json",
    "generate:error-rules": "node scripts/generate-error-rules.ts",
    "package:docnav": "node scripts/package-docnav.ts",
    "info:docnav-package": "node scripts/release-package-info.ts",
    "cli:dev": "node scripts/with-cargo-bins.ts --bin docnav docnav DOCNAV_BIN --bin docnav-markdown docnav-markdown DOCNAV_MARKDOWN_BIN -- node scripts/run-docnav-dev.ts",
    "dnm": "node scripts/with-cargo-bins.ts --quiet --bin docnav-markdown docnav-markdown DOCNAV_MARKDOWN_BIN -- node scripts/run-docnav-dev.ts docnav-markdown",
    "smoke:docnav-core:dev": "node scripts/with-cargo-bins.ts --bin docnav docnav DOCNAV_BIN --bin docnav-markdown docnav-markdown DOCNAV_MARKDOWN_BIN -- node test/docnav-core-smoke.ts",
    "smoke:docnav-markdown:dev": "node scripts/with-cargo-bins.ts --bin docnav-markdown docnav-markdown DOCNAV_MARKDOWN_BIN -- node test/docnav-markdown-smoke.ts",
    "smoke:docnav": "node scripts/smoke-docnav-dev.ts",
    "verify:docnav-package": "node scripts/verify-docnav-package.ts",
    "smoke:docnav-package": "node scripts/docnav-package-smoke.ts",
    "test:workspace-verifier": "node --test scripts/tools/verify-docnav-workspace.test.ts test/tools/smoke-harness.test.ts scripts/tools/parallel-task-runner.test.ts",
    "test:release-package-scripts": "node --test scripts/tools/release-package/args.test.ts",
    "verify:docnav-workspace": "node scripts/verify-docnav-workspace.ts",
    "verify:docnav-workspace:required": "node scripts/verify-docnav-workspace.ts --profile required",
    "verify:docnav-workspace:full": "node scripts/verify-docnav-workspace.ts --profile full",
    "validate": "pnpm run validate:generated && pnpm run validate:docs && pnpm run validate:openspec && pnpm run validate:diff",
    "validate:docs": "node scripts/validate-docs.ts",
    "validate:generated": "node scripts/generate-error-rules.ts --check",
    "validate:openspec": "openspec validate --all --strict",
    "validate:diff": "git diff --check",
    "quality:scan": "node scripts/quality-scan.ts",
    "quality:annotate": "node scripts/quality-annotate.ts",
    "quality:test": "node --test scripts/tools/quality/*.test.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@fission-ai/openspec": "1.3.1",
    "@types/node": "^24.13.2",
    "ajv": "^8.17.1",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "minimatch": "^10.2.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  }
}
