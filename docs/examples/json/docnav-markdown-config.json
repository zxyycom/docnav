{
  "defaults": {
    "pagination": {
      "enabled": true,
      "limit": 6000
    },
    "output": "readable-view"
  },
  "invocation_log": {
    "enabled": true,
    "path": "logs/docnav-invocations.jsonl",
    "content_capture": {
      "enabled": true,
      "root": "logs/docnav-content"
    }
  },
  "options": {
    "docnav-markdown": {
      "max_heading_level": 3
    }
  }
}
