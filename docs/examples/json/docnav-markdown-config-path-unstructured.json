{
  "outline": {
    "mode_rules": [
      {
        "path": "notes/raw/.+\\.md",
        "mode": "unstructured_full"
      },
      {
        "path": "notes/raw/index\\.md",
        "mode": "structured"
      }
    ]
  },
  "options": {
    "docnav-markdown": {
      "max_heading_level": 3
    }
  }
}
