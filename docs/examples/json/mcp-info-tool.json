{
  "name": "document_info",
  "description": "返回文档格式和适配器能力摘要。",
  "inputSchema": {
    "type": "object",
    "required": [
      "path"
    ],
    "properties": {
      "path": {
        "type": "string"
      },
      "adapter": {
        "type": "string",
        "minLength": 1
      },
      "options": {
        "type": "object"
      }
    },
    "additionalProperties": false
  },
  "outputSchema": {
    "type": "object",
    "required": [
      "display",
      "capabilities"
    ],
    "properties": {
      "display": {
        "type": "string",
        "minLength": 1
      },
      "capabilities": {
        "type": "array",
        "items": {
          "enum": [
            "outline",
            "read",
            "find",
            "info"
          ]
        },
        "uniqueItems": true
      },
      "warnings": {
        "type": "array",
        "items": {
          "type": "object",
          "required": [
            "ignored_tokens",
            "kind",
            "reason"
          ],
          "properties": {
            "ignored_tokens": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "kind": {
              "type": "string",
              "minLength": 1
            },
            "reason": {
              "type": "string",
              "minLength": 1
            },
            "adapter_id": {
              "type": "string",
              "minLength": 1
            },
            "stage": {
              "enum": [
                "resolve",
                "probe"
              ]
            },
            "code": {
              "type": "string",
              "minLength": 1
            }
          },
          "allOf": [
            {
              "if": {
                "properties": {
                  "kind": {
                    "const": "adapter_candidate_failure"
                  }
                },
                "required": [
                  "kind"
                ]
              },
              "then": {
                "properties": {
                  "adapter_id": {
                    "type": "string",
                    "minLength": 1
                  },
                  "stage": {
                    "enum": [
                      "resolve",
                      "probe"
                    ]
                  },
                  "code": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "required": [
                  "adapter_id",
                  "stage",
                  "code"
                ]
              }
            }
          ],
          "additionalProperties": false
        }
      }
    },
    "additionalProperties": false
  }
}
