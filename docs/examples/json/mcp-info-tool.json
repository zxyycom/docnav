{
  "name": "document_info",
  "description": "返回文档格式和适配器能力摘要。",
  "inputSchema": {
    "type": "object",
    "required": [
      "path"
    ],
    "properties": {
      "path": {
        "type": "string"
      },
      "adapter": {
        "type": "string",
        "minLength": 1
      },
      "options": {
        "type": "object"
      }
    },
    "additionalProperties": false
  },
  "outputSchema": {
    "type": "object",
    "required": [
      "display",
      "capabilities"
    ],
    "properties": {
      "display": {
        "type": "string",
        "minLength": 1
      },
      "capabilities": {
        "type": "array",
        "items": {
          "enum": [
            "outline",
            "read",
            "find",
            "info"
          ]
        },
        "uniqueItems": true
      },
      "warnings": {
        "type": "array",
        "items": {
          "type": "object",
          "required": [
            "ignored_tokens",
            "kind",
            "reason"
          ],
          "properties": {
            "ignored_tokens": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "minItems": 1
            },
            "kind": {
              "type": "string",
              "minLength": 1
            },
            "reason": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": false
        }
      }
    },
    "additionalProperties": false
  }
}
