{
  "name": "document_read",
  "description": "使用 ref 读取有限文档内容。",
  "inputSchema": {
    "type": "object",
    "required": [
      "path",
      "ref"
    ],
    "properties": {
      "path": {
        "type": "string"
      },
      "adapter": {
        "type": "string",
        "minLength": 1
      },
      "ref": {
        "type": "string",
        "minLength": 1
      },
      "page": {
        "type": "integer",
        "minimum": 1
      },
      "limit_chars": {
        "type": "integer",
        "minimum": 1
      }
    },
    "additionalProperties": false
  },
  "outputSchema": {
    "type": "object",
    "required": [
      "ref",
      "content",
      "content_type",
      "cost",
      "page"
    ],
    "properties": {
      "ref": {
        "type": "string",
        "minLength": 1
      },
      "content": {
        "type": "string"
      },
      "content_type": {
        "type": "string",
        "minLength": 1
      },
      "cost": {
        "type": "string",
        "minLength": 1
      },
      "page": {
        "type": [
          "integer",
          "null"
        ],
        "minimum": 1
      },
      "warnings": {
        "type": "array",
        "items": {
          "type": "object",
          "required": [
            "id",
            "reason",
            "effect",
            "details"
          ],
          "properties": {
            "id": {
              "enum": [
                "cli_argv_ignored",
                "adapter_candidate_failure"
              ]
            },
            "reason": {
              "type": "string",
              "minLength": 1
            },
            "effect": {
              "enum": [
                "operation_continued",
                "candidate_skipped",
                "diagnostic_only"
              ]
            },
            "details": {
              "type": "object"
            }
          },
          "allOf": [
            {
              "if": {
                "properties": {
                  "id": {
                    "const": "cli_argv_ignored"
                  }
                },
                "required": [
                  "id"
                ]
              },
              "then": {
                "properties": {
                  "effect": {
                    "enum": [
                      "operation_continued",
                      "diagnostic_only"
                    ]
                  },
                  "details": {
                    "type": "object",
                    "required": [
                      "tokens"
                    ],
                    "properties": {
                      "tokens": {
                        "type": "array",
                        "minItems": 1,
                        "items": {
                          "type": "string",
                          "minLength": 1
                        }
                      }
                    },
                    "additionalProperties": false
                  }
                }
              }
            },
            {
              "if": {
                "properties": {
                  "id": {
                    "const": "adapter_candidate_failure"
                  }
                },
                "required": [
                  "id"
                ]
              },
              "then": {
                "properties": {
                  "effect": {
                    "const": "candidate_skipped"
                  },
                  "details": {
                    "type": "object",
                    "required": [
                      "adapter_id",
                      "stage",
                      "code"
                    ],
                    "properties": {
                      "adapter_id": {
                        "type": "string",
                        "minLength": 1
                      },
                      "stage": {
                        "enum": [
                          "resolve",
                          "probe"
                        ]
                      },
                      "code": {
                        "type": "string",
                        "minLength": 1
                      },
                      "preselected": {
                        "type": "boolean"
                      }
                    },
                    "additionalProperties": false
                  }
                }
              }
            }
          ],
          "additionalProperties": false
        }
      }
    },
    "additionalProperties": false
  }
}
