{
  "name": "document_read",
  "description": "使用 ref 读取有限文档内容。",
  "inputSchema": {
    "type": "object",
    "required": [
      "path",
      "ref"
    ],
    "properties": {
      "path": {
        "type": "string"
      },
      "adapter": {
        "type": "string",
        "minLength": 1
      },
      "ref": {
        "type": "string",
        "minLength": 1
      },
      "page": {
        "type": "integer",
        "minimum": 1
      },
      "limit_chars": {
        "type": "integer",
        "minimum": 1
      }
    },
    "additionalProperties": false
  },
  "outputSchema": {
    "type": "object",
    "required": [
      "ref",
      "content",
      "content_type",
      "cost",
      "page"
    ],
    "properties": {
      "ref": {
        "type": "string",
        "minLength": 1
      },
      "content": {
        "type": "string"
      },
      "content_type": {
        "type": "string",
        "minLength": 1
      },
      "cost": {
        "type": "string",
        "minLength": 1
      },
      "page": {
        "type": [
          "integer",
          "null"
        ],
        "minimum": 1
      },
      "warnings": {
        "type": "array",
        "items": {
          "type": "object",
          "required": [
            "ignored_tokens",
            "kind",
            "reason"
          ],
          "properties": {
            "ignored_tokens": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "kind": {
              "type": "string",
              "minLength": 1
            },
            "reason": {
              "type": "string",
              "minLength": 1
            },
            "adapter_id": {
              "type": "string",
              "minLength": 1
            },
            "stage": {
              "enum": [
                "resolve",
                "probe"
              ]
            },
            "code": {
              "type": "string",
              "minLength": 1
            }
          },
          "allOf": [
            {
              "if": {
                "properties": {
                  "kind": {
                    "const": "adapter_candidate_failure"
                  }
                },
                "required": [
                  "kind"
                ]
              },
              "then": {
                "properties": {
                  "adapter_id": {
                    "type": "string",
                    "minLength": 1
                  },
                  "stage": {
                    "enum": [
                      "resolve",
                      "probe"
                    ]
                  },
                  "code": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "required": [
                  "adapter_id",
                  "stage",
                  "code"
                ]
              }
            }
          ],
          "additionalProperties": false
        }
      }
    },
    "additionalProperties": false
  }
}
