{
  "name": "document_outline",
  "description": "返回有限的扁平文档导航条目。",
  "inputSchema": {
    "type": "object",
    "required": [
      "path"
    ],
    "properties": {
      "path": {
        "type": "string"
      },
      "adapter": {
        "type": "string",
        "minLength": 1
      },
      "limit_chars": {
        "type": "integer",
        "minimum": 1
      },
      "page": {
        "type": "integer",
        "minimum": 1
      },
      "options": {
        "type": "object"
      }
    },
    "additionalProperties": false
  },
  "outputSchema": {
    "type": "object",
    "required": [
      "entries",
      "page"
    ],
    "properties": {
      "entries": {
        "type": "array",
        "items": {
          "type": "object",
          "required": [
            "ref",
            "display"
          ],
          "properties": {
            "ref": {
              "type": "string",
              "minLength": 1
            },
            "display": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": false
        }
      },
      "page": {
        "type": [
          "integer",
          "null"
        ],
        "minimum": 1
      },
      "warnings": {
        "type": "array",
        "items": {
          "type": "object",
          "required": [
            "ignored_tokens",
            "kind",
            "reason"
          ],
          "properties": {
            "ignored_tokens": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "kind": {
              "type": "string",
              "minLength": 1
            },
            "reason": {
              "type": "string",
              "minLength": 1
            },
            "adapter_id": {
              "type": "string",
              "minLength": 1
            },
            "stage": {
              "enum": [
                "resolve",
                "probe"
              ]
            },
            "code": {
              "type": "string",
              "minLength": 1
            }
          },
          "allOf": [
            {
              "if": {
                "properties": {
                  "kind": {
                    "const": "adapter_candidate_failure"
                  }
                },
                "required": [
                  "kind"
                ]
              },
              "then": {
                "properties": {
                  "adapter_id": {
                    "type": "string",
                    "minLength": 1
                  },
                  "stage": {
                    "enum": [
                      "resolve",
                      "probe"
                    ]
                  },
                  "code": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "required": [
                  "adapter_id",
                  "stage",
                  "code"
                ]
              }
            }
          ],
          "additionalProperties": false
        }
      }
    },
    "additionalProperties": false
  }
}
