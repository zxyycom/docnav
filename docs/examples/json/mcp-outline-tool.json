{
  "name": "document_outline",
  "description": "返回有限的扁平文档导航条目。",
  "inputSchema": {
    "type": "object",
    "required": [
      "path"
    ],
    "properties": {
      "path": {
        "type": "string"
      },
      "format": {
        "type": "string",
        "minLength": 1
      },
      "limit_chars": {
        "type": "integer",
        "minimum": 1
      },
      "page": {
        "type": "integer",
        "minimum": 1
      },
      "options": {
        "type": "object"
      }
    },
    "additionalProperties": false
  },
  "outputSchema": {
    "type": "object",
    "required": [
      "entries",
      "page"
    ],
    "properties": {
      "entries": {
        "type": "array",
        "items": {
          "type": "object",
          "required": [
            "ref",
            "display"
          ],
          "properties": {
            "ref": {
              "type": "string",
              "minLength": 1
            },
            "display": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": false
        }
      },
      "page": {
        "type": [
          "integer",
          "null"
        ],
        "minimum": 1
      }
    },
    "additionalProperties": false
  }
}
