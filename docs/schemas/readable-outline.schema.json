{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://docnav.dev/schemas/v0.1/readable-outline.schema.json",
  "oneOf": [
    {
      "$ref": "#/$defs/structuredOutline"
    },
    {
      "$ref": "#/$defs/unstructuredOutline"
    }
  ],
  "$defs": {
    "measurement": {
      "type": "object",
      "required": [
        "unit",
        "value"
      ],
      "properties": {
        "unit": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": "integer",
          "minimum": 0
        },
        "scope": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "cost": {
      "type": "object",
      "required": [
        "measurements"
      ],
      "properties": {
        "measurements": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/measurement"
          }
        }
      },
      "additionalProperties": false
    },
    "structuredOutline": {
      "type": "object",
      "required": [
        "kind",
        "entries",
        "page"
      ],
      "properties": {
        "kind": {
          "const": "structured"
        },
        "entries": {
          "type": "array",
          "items": {
            "$ref": "readable-common.schema.json#/$defs/entry"
          }
        },
        "page": {
          "$ref": "readable-common.schema.json#/$defs/page"
        }
      },
      "additionalProperties": false
    },
    "unstructuredOutline": {
      "type": "object",
      "required": [
        "kind",
        "reason",
        "content",
        "content_type",
        "cost"
      ],
      "properties": {
        "kind": {
          "const": "unstructured"
        },
        "reason": {
          "enum": [
            "path_rule",
            "cost_threshold"
          ]
        },
        "content": {
          "type": "string"
        },
        "content_type": {
          "type": "string",
          "minLength": 1
        },
        "cost": {
          "$ref": "#/$defs/cost"
        }
      },
      "additionalProperties": false
    }
  }
}
