{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://docnav.dev/schemas/v0.1/readable-outline.schema.json",
  "type": "object",
  "required": [
    "entries",
    "page"
  ],
  "properties": {
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "ref",
          "display"
        ],
        "properties": {
          "ref": {
            "type": "string",
            "minLength": 1
          },
          "display": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "page": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 1
    }
  },
  "additionalProperties": false
}
