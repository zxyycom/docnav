{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://docnav.dev/schemas/v0.1/readable-find.schema.json",
  "type": "object",
  "required": [
    "matches",
    "page"
  ],
  "properties": {
    "matches": {
      "type": "array",
      "items": {
        "$ref": "readable-common.schema.json#/$defs/entry"
      }
    },
    "page": {
      "$ref": "readable-common.schema.json#/$defs/page"
    },
    "warnings": {
      "$ref": "readable-common.schema.json#/$defs/warnings"
    }
  },
  "additionalProperties": false
}
