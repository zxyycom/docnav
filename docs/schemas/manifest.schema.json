{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://docnav.dev/schemas/v0.1/manifest.schema.json",
  "type": "object",
  "required": [
    "manifest_version",
    "adapter",
    "formats"
  ],
  "properties": {
    "manifest_version": {
      "const": "0.1"
    },
    "adapter": {
      "type": "object",
      "required": [
        "id",
        "name",
        "version"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "formats": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "extensions",
          "content_types"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "extensions": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^\\.[A-Za-z0-9][A-Za-z0-9._-]*$"
            }
          },
          "content_types": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
