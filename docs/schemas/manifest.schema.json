{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://docnav.dev/schemas/v0.1/manifest.schema.json",
  "type": "object",
  "required": [
    "manifest_version",
    "adapter",
    "protocol",
    "formats",
    "capabilities",
    "recommended_parameters"
  ],
  "properties": {
    "manifest_version": {
      "const": "0.1"
    },
    "adapter": {
      "type": "object",
      "required": [
        "id",
        "name",
        "version"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "protocol": {
      "type": "object",
      "required": [
        "min",
        "max"
      ],
      "properties": {
        "min": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+$"
        },
        "max": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+$"
        }
      },
      "additionalProperties": false
    },
    "formats": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "extensions",
          "content_types"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "extensions": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^\\.[A-Za-z0-9][A-Za-z0-9._-]*$"
            }
          },
          "content_types": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "additionalProperties": false
      }
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "outline",
          "read",
          "find",
          "info"
        ]
      },
      "uniqueItems": true
    },
    "recommended_parameters": {
      "type": "object",
      "properties": {
        "outline": {
          "$ref": "#/$defs/pagedOperationParameters"
        },
        "read": {
          "$ref": "#/$defs/pagedOperationParameters"
        },
        "find": {
          "$ref": "#/$defs/pagedOperationParameters"
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "pagedOperationParameters": {
      "type": "object",
      "required": [
        "limit_chars"
      ],
      "properties": {
        "limit_chars": {
          "type": "integer",
          "minimum": 1
        },
        "options": {
          "type": "object"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
