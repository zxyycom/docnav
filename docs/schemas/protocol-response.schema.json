{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://docnav.dev/schemas/v0.1/protocol-response.schema.json",
  "$comment": "Validates protocol surface shape.",
  "oneOf": [
    {
      "$ref": "#/$defs/success"
    },
    {
      "$ref": "#/$defs/failure"
    }
  ],
  "$defs": {
    "operation": {
      "enum": [
        "outline",
        "read",
        "find",
        "info"
      ]
    },
    "entry": {
      "type": "object",
      "required": [
        "ref",
        "label"
      ],
      "properties": {
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "location": {
          "$ref": "#/$defs/location"
        },
        "summary": {
          "type": "string"
        },
        "excerpt": {
          "type": "string"
        },
        "rank": {
          "type": "number"
        },
        "cost": {
          "$ref": "#/$defs/cost"
        },
        "metadata": {
          "type": "object"
        }
      },
      "additionalProperties": false
    },
    "location": {
      "type": "object",
      "required": [
        "line_start"
      ],
      "properties": {
        "line_start": {
          "type": "integer",
          "minimum": 1
        },
        "line_end": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "measurement": {
      "type": "object",
      "required": [
        "unit",
        "value"
      ],
      "properties": {
        "unit": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": "integer",
          "minimum": 0
        },
        "scope": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "cost": {
      "type": "object",
      "required": [
        "measurements"
      ],
      "properties": {
        "measurements": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/measurement"
          }
        }
      },
      "additionalProperties": false
    },
    "costMaybeEmpty": {
      "type": "object",
      "required": [
        "measurements"
      ],
      "properties": {
        "measurements": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/measurement"
          }
        }
      },
      "additionalProperties": false
    },
    "page": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 1
    },
    "outlineReason": {
      "enum": [
        "path_rule",
        "cost_threshold"
      ]
    },
    "outlineResult": {
      "oneOf": [
        {
          "$ref": "#/$defs/structuredOutlineResult"
        },
        {
          "$ref": "#/$defs/unstructuredOutlineResult"
        }
      ]
    },
    "structuredOutlineResult": {
      "type": "object",
      "required": [
        "kind",
        "entries",
        "page"
      ],
      "properties": {
        "kind": {
          "const": "structured"
        },
        "entries": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/entry"
          }
        },
        "page": {
          "$ref": "#/$defs/page"
        }
      },
      "additionalProperties": false
    },
    "unstructuredOutlineResult": {
      "type": "object",
      "required": [
        "kind",
        "reason",
        "content",
        "content_type",
        "cost"
      ],
      "properties": {
        "kind": {
          "const": "unstructured"
        },
        "reason": {
          "$ref": "#/$defs/outlineReason"
        },
        "content": {
          "type": "string"
        },
        "content_type": {
          "type": "string",
          "minLength": 1
        },
        "cost": {
          "$ref": "#/$defs/costMaybeEmpty"
        }
      },
      "additionalProperties": false
    },
    "readResult": {
      "type": "object",
      "required": [
        "ref",
        "content",
        "content_type",
        "cost",
        "page"
      ],
      "properties": {
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "content": {
          "type": "string"
        },
        "content_type": {
          "type": "string",
          "minLength": 1
        },
        "cost": {
          "$ref": "#/$defs/cost"
        },
        "page": {
          "$ref": "#/$defs/page"
        }
      },
      "additionalProperties": false
    },
    "findResult": {
      "type": "object",
      "required": [
        "matches",
        "page"
      ],
      "properties": {
        "matches": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/entry"
          }
        },
        "page": {
          "$ref": "#/$defs/page"
        }
      },
      "additionalProperties": false
    },
    "infoResult": {
      "type": "object",
      "properties": {
        "document": {
          "type": "object",
          "properties": {
            "content_type": {
              "type": "string",
              "minLength": 1
            },
            "encoding": {
              "type": "string",
              "minLength": 1
            },
            "size": {
              "$ref": "#/$defs/measurement"
            }
          },
          "additionalProperties": false
        },
        "adapter": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "minLength": 1
            },
            "format": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": false
        },
        "metadata": {
          "type": "object"
        }
      },
      "additionalProperties": false
    },
    "baseSuccess": {
      "type": "object",
      "required": [
        "protocol_version",
        "request_id",
        "operation",
        "ok",
        "result"
      ],
      "properties": {
        "protocol_version": {
          "const": "0.1"
        },
        "request_id": {
          "type": "string",
          "minLength": 1
        },
        "operation": {
          "$ref": "#/$defs/operation"
        },
        "ok": {
          "const": true
        },
        "result": {
          "type": "object"
        }
      },
      "additionalProperties": false
    },
    "success": {
      "allOf": [
        {
          "$ref": "#/$defs/baseSuccess"
        },
        {
          "oneOf": [
            {
              "type": "object",
              "properties": {
                "operation": {
                  "const": "outline"
                },
                "result": {
                  "$ref": "#/$defs/outlineResult"
                }
              }
            },
            {
              "type": "object",
              "properties": {
                "operation": {
                  "const": "read"
                },
                "result": {
                  "$ref": "#/$defs/readResult"
                }
              }
            },
            {
              "type": "object",
              "properties": {
                "operation": {
                  "const": "find"
                },
                "result": {
                  "$ref": "#/$defs/findResult"
                }
              }
            },
            {
              "type": "object",
              "properties": {
                "operation": {
                  "const": "info"
                },
                "result": {
                  "$ref": "#/$defs/infoResult"
                }
              }
            }
          ]
        }
      ]
    },
    "failure": {
      "type": "object",
      "required": [
        "protocol_version",
        "request_id",
        "operation",
        "ok",
        "error"
      ],
      "properties": {
        "protocol_version": {
          "const": "0.1"
        },
        "request_id": {
          "type": "string",
          "minLength": 1
        },
        "operation": {
          "oneOf": [
            {
              "$ref": "#/$defs/operation"
            },
            {
              "type": "null"
            }
          ]
        },
        "ok": {
          "const": false
        },
        "error": {
          "type": "object",
          "required": [
            "code",
            "message",
            "owner",
            "details"
          ],
          "properties": {
            "code": {
              "enum": [
                "INVALID_REQUEST",
                "DOCUMENT_NOT_FOUND",
                "DOCUMENT_PATH_INVALID",
                "DOCUMENT_ENCODING_UNSUPPORTED",
                "FORMAT_UNKNOWN",
                "FORMAT_AMBIGUOUS",
                "REF_NOT_FOUND",
                "REF_AMBIGUOUS",
                "REF_INVALID",
                "ADAPTER_UNAVAILABLE",
                "INTERNAL_ERROR"
              ]
            },
            "message": {
              "type": "string",
              "minLength": 1
            },
            "owner": {
              "type": "string",
              "minLength": 1
            },
            "location": {
              "type": "object",
              "minProperties": 1
            },
            "received": {},
            "expected": {},
            "guidance": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "details": {
              "type": "object"
            }
          },
          "additionalProperties": false,
          "allOf": [
            {
              "if": {
                "type": "object",
                "properties": {
                  "code": {
                    "const": "INVALID_REQUEST"
                  }
                }
              },
              "then": {
                "type": "object",
                "properties": {
                  "details": {
                    "$ref": "#/$defs/protocolErrorDetailsInvalidRequest"
                  }
                }
              }
            },
            {
              "if": {
                "type": "object",
                "properties": {
                  "code": {
                    "const": "DOCUMENT_NOT_FOUND"
                  }
                }
              },
              "then": {
                "type": "object",
                "properties": {
                  "details": {
                    "$ref": "#/$defs/protocolErrorDetailsPath"
                  }
                }
              }
            },
            {
              "if": {
                "type": "object",
                "properties": {
                  "code": {
                    "const": "DOCUMENT_PATH_INVALID"
                  }
                }
              },
              "then": {
                "type": "object",
                "properties": {
                  "details": {
                    "$ref": "#/$defs/protocolErrorDetailsPathReason"
                  }
                }
              }
            },
            {
              "if": {
                "type": "object",
                "properties": {
                  "code": {
                    "const": "DOCUMENT_ENCODING_UNSUPPORTED"
                  }
                }
              },
              "then": {
                "type": "object",
                "properties": {
                  "details": {
                    "$ref": "#/$defs/protocolErrorDetailsPathEncoding"
                  }
                }
              }
            },
            {
              "if": {
                "type": "object",
                "properties": {
                  "code": {
                    "const": "FORMAT_UNKNOWN"
                  }
                }
              },
              "then": {
                "type": "object",
                "properties": {
                  "details": {
                    "$ref": "#/$defs/protocolErrorDetailsFormatUnknown"
                  }
                }
              }
            },
            {
              "if": {
                "type": "object",
                "properties": {
                  "code": {
                    "const": "FORMAT_AMBIGUOUS"
                  }
                }
              },
              "then": {
                "type": "object",
                "properties": {
                  "details": {
                    "$ref": "#/$defs/protocolErrorDetailsFormatAmbiguous"
                  }
                }
              }
            },
            {
              "if": {
                "type": "object",
                "properties": {
                  "code": {
                    "const": "REF_NOT_FOUND"
                  }
                }
              },
              "then": {
                "type": "object",
                "properties": {
                  "details": {
                    "$ref": "#/$defs/protocolErrorDetailsRef"
                  }
                }
              }
            },
            {
              "if": {
                "type": "object",
                "properties": {
                  "code": {
                    "const": "REF_AMBIGUOUS"
                  }
                }
              },
              "then": {
                "type": "object",
                "properties": {
                  "details": {
                    "$ref": "#/$defs/protocolErrorDetailsRefCandidate"
                  }
                }
              }
            },
            {
              "if": {
                "type": "object",
                "properties": {
                  "code": {
                    "const": "REF_INVALID"
                  }
                }
              },
              "then": {
                "type": "object",
                "properties": {
                  "details": {
                    "$ref": "#/$defs/protocolErrorDetailsRefReason"
                  }
                }
              }
            },
            {
              "if": {
                "type": "object",
                "properties": {
                  "code": {
                    "const": "ADAPTER_UNAVAILABLE"
                  }
                }
              },
              "then": {
                "type": "object",
                "properties": {
                  "details": {
                    "$ref": "#/$defs/protocolErrorDetailsAdapterIdReason"
                  }
                }
              }
            },
            {
              "if": {
                "type": "object",
                "properties": {
                  "code": {
                    "const": "INTERNAL_ERROR"
                  }
                }
              },
              "then": {
                "type": "object",
                "properties": {
                  "details": {
                    "$ref": "#/$defs/protocolErrorDetailsInternal"
                  }
                }
              }
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "protocolErrorDetailsAdapterIdReason": {
      "type": "object",
      "required": [
        "adapter_id",
        "reason"
      ],
      "properties": {
        "adapter_id": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "selection_source": {
          "type": "string",
          "minLength": 1
        },
        "stage": {
          "enum": [
            "resolve",
            "probe"
          ]
        }
      },
      "additionalProperties": false
    },
    "protocolErrorDetailsInvalidRequest": {
      "type": "object",
      "required": [
        "field",
        "reason"
      ],
      "properties": {
        "field": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "received": {
          "type": "string"
        },
        "accepted": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "field_issues": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "config_issues": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "typed_validation_failures": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "option_issues": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/protocolOptionIssue"
          }
        }
      },
      "additionalProperties": false
    },
    "protocolOptionIssue": {
      "type": "object",
      "required": [
        "owner",
        "namespace",
        "key",
        "source",
        "reason_code"
      ],
      "properties": {
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "namespace": {
          "type": "string",
          "minLength": 1
        },
        "key": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "type_variant": {
          "type": "string",
          "minLength": 1
        },
        "reason_code": {
          "type": "string",
          "minLength": 1
        },
        "received": {},
        "expected": {},
        "location": {
          "type": "object",
          "minProperties": 1
        }
      },
      "additionalProperties": false
    },
    "protocolErrorDetailsPath": {
      "type": "object",
      "required": [
        "path"
      ],
      "properties": {
        "path": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "protocolErrorDetailsPathReason": {
      "type": "object",
      "required": [
        "path",
        "reason"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "protocolErrorDetailsPathEncoding": {
      "type": "object",
      "required": [
        "path",
        "encoding"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "encoding": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "protocolFormatCandidate": {
      "type": "object",
      "required": [
        "adapter_id",
        "stage",
        "reason"
      ],
      "properties": {
        "adapter_id": {
          "type": "string",
          "minLength": 1
        },
        "stage": {
          "enum": [
            "resolve",
            "probe"
          ]
        },
        "reason": {
          "enum": [
            "ADAPTER_NOT_FOUND",
            "ADAPTER_UNAVAILABLE",
            "PROBE_INVALID",
            "PROBE_UNSUPPORTED",
            "CONTENT_MATCH"
          ]
        }
      },
      "additionalProperties": false
    },
    "protocolErrorDetailsFormatUnknown": {
      "type": "object",
      "required": [
        "path",
        "reason",
        "candidates"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "reason": {
          "const": "NO_SUPPORTED_ADAPTER"
        },
        "candidates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/protocolFormatCandidate"
          }
        },
        "candidate_failures": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/protocolFormatCandidate"
          }
        }
      },
      "additionalProperties": false
    },
    "protocolErrorDetailsFormatAmbiguous": {
      "type": "object",
      "required": [
        "path",
        "candidates"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "candidates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/protocolFormatCandidate"
          }
        },
        "candidate_failures": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/protocolFormatCandidate"
          }
        }
      },
      "additionalProperties": false
    },
    "protocolErrorDetailsRef": {
      "type": "object",
      "required": [
        "ref"
      ],
      "properties": {
        "ref": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "protocolErrorDetailsRefCandidate": {
      "type": "object",
      "required": [
        "ref",
        "candidate_count"
      ],
      "properties": {
        "ref": {
          "type": "string"
        },
        "candidate_count": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4294967295
        }
      },
      "additionalProperties": false
    },
    "protocolErrorDetailsRefReason": {
      "type": "object",
      "required": [
        "ref",
        "reason"
      ],
      "properties": {
        "ref": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "protocolErrorDetailsInternal": {
      "type": "object",
      "required": [
        "error_id"
      ],
      "properties": {
        "error_id": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
