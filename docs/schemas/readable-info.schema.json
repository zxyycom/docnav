{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://docnav.dev/schemas/v0.1/readable-info.schema.json",
  "type": "object",
  "required": [
    "display",
    "capabilities"
  ],
  "properties": {
    "display": {
      "type": "string",
      "minLength": 1
    },
    "capabilities": {
      "type": "array",
      "items": {
        "enum": [
          "outline",
          "read",
          "find",
          "info"
        ]
      },
      "uniqueItems": true
    },
    "warnings": {
      "$ref": "#/$defs/warnings"
    }
  },
  "$defs": {
    "warnings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "ignored_tokens",
          "kind",
          "reason"
        ],
        "properties": {
          "ignored_tokens": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 1
          },
          "kind": {
            "type": "string",
            "minLength": 1
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
