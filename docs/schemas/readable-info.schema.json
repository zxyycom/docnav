{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://docnav.dev/schemas/v0.1/readable-info.schema.json",
  "type": "object",
  "required": [
    "display",
    "capabilities"
  ],
  "properties": {
    "display": {
      "type": "string",
      "minLength": 1
    },
    "capabilities": {
      "type": "array",
      "items": {
        "$ref": "readable-common.schema.json#/$defs/capability"
      },
      "uniqueItems": true
    },
    "warnings": {
      "$ref": "readable-common.schema.json#/$defs/warnings"
    }
  },
  "additionalProperties": false
}
