{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://docnav.dev/schemas/v0.1/readable-common.schema.json",
  "$defs": {
    "capability": {
      "enum": [
        "outline",
        "read",
        "find",
        "info"
      ]
    },
    "entry": {
      "type": "object",
      "required": [
        "ref",
        "display"
      ],
      "properties": {
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "display": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "page": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 1
    },
    "warning": {
      "type": "object",
      "required": [
        "id",
        "reason",
        "effect",
        "details"
      ],
      "properties": {
        "id": {
          "enum": [
            "cli_argv_ignored",
            "adapter_candidate_failure"
          ]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "effect": {
          "enum": [
            "operation_continued",
            "candidate_skipped",
            "diagnostic_only"
          ]
        },
        "details": {
          "type": "object"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "id": {
                "const": "cli_argv_ignored"
              }
            },
            "required": [
              "id"
            ]
          },
          "then": {
            "properties": {
              "effect": {
                "enum": [
                  "operation_continued",
                  "diagnostic_only"
                ]
              },
              "details": {
                "type": "object",
                "required": [
                  "tokens"
                ],
                "properties": {
                  "tokens": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "string",
                      "minLength": 1
                    }
                  }
                },
                "additionalProperties": false
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "id": {
                "const": "adapter_candidate_failure"
              }
            },
            "required": [
              "id"
            ]
          },
          "then": {
            "properties": {
              "effect": {
                "const": "candidate_skipped"
              },
              "details": {
                "type": "object",
                "required": [
                  "adapter_id",
                  "stage",
                  "code"
                ],
                "properties": {
                  "adapter_id": {
                    "type": "string",
                    "minLength": 1
                  },
                  "stage": {
                    "enum": [
                      "resolve",
                      "probe"
                    ]
                  },
                  "code": {
                    "type": "string",
                    "minLength": 1
                  },
                  "preselected": {
                    "type": "boolean"
                  }
                },
                "additionalProperties": false
              }
            }
          }
        }
      ],
      "additionalProperties": false
    },
    "warnings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/warning"
      }
    }
  }
}
