{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://docnav.dev/schemas/v0.1/readable-common.schema.json",
  "$defs": {
    "entry": {
      "type": "object",
      "required": [
        "ref",
        "display"
      ],
      "properties": {
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "display": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "page": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 1
    },
    "diagnosticLocation": {
      "type": "object",
      "minProperties": 1
    },
    "candidateFailure": {
      "type": "object",
      "required": [
        "adapter_id",
        "stage",
        "reason"
      ],
      "properties": {
        "adapter_id": {
          "type": "string",
          "minLength": 1
        },
        "stage": {
          "enum": [
            "resolve",
            "probe"
          ]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "diagnosticDetails": {
      "type": "object",
      "properties": {
        "field_issues": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "config_issues": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "typed_validation_failures": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "option_issues": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/optionIssue"
          }
        },
        "candidate_failures": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/candidateFailure"
          }
        }
      },
      "additionalProperties": true
    },
    "optionIssue": {
      "type": "object",
      "required": [
        "owner",
        "namespace",
        "key",
        "source",
        "reason_code"
      ],
      "properties": {
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "namespace": {
          "type": "string",
          "minLength": 1
        },
        "key": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "type_variant": {
          "type": "string",
          "minLength": 1
        },
        "reason_code": {
          "type": "string",
          "minLength": 1
        },
        "received": {},
        "expected": {},
        "location": {
          "type": "object",
          "minProperties": 1
        }
      },
      "additionalProperties": false
    },
    "guidance": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
