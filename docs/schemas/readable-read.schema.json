{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://docnav.dev/schemas/v0.1/readable-read.schema.json",
  "type": "object",
  "required": [
    "ref",
    "content",
    "content_type",
    "cost",
    "page"
  ],
  "properties": {
    "ref": {
      "type": "string",
      "minLength": 1
    },
    "content": {
      "type": "string"
    },
    "content_type": {
      "type": "string",
      "minLength": 1
    },
    "cost": {
      "type": "string",
      "minLength": 1
    },
    "page": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 1
    },
    "warnings": {
      "$ref": "#/$defs/warnings"
    }
  },
  "$defs": {
    "warnings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "ignored_tokens",
          "kind",
          "reason"
        ],
        "properties": {
          "ignored_tokens": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "minItems": 1
          },
          "kind": {
            "type": "string",
            "minLength": 1
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
