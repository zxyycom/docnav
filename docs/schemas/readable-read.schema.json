{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://docnav.dev/schemas/v0.1/readable-read.schema.json",
  "type": "object",
  "required": [
    "ref",
    "content",
    "content_type",
    "cost",
    "page"
  ],
  "properties": {
    "ref": {
      "type": "string",
      "minLength": 1
    },
    "content": {
      "type": "string"
    },
    "content_type": {
      "type": "string",
      "minLength": 1
    },
    "cost": {
      "type": "string",
      "minLength": 1
    },
    "page": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 1
    }
  },
  "additionalProperties": false
}
